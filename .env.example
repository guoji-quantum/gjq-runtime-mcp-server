# GuoJi Quantum Cloud account (obtain your API key from https://www.tiangongqs.com/cloud)
GJQ_API_KEY=

# Channel: "gjq_cloud" (real hardware / cloud) or "local"
GJQ_CHANNEL=gjq_cloud

# Optional: override auth and backend service URLs (leave empty to use defaults)
GJQ_BASE_URL=
GJQ_BACKEND_URL=

# Anti-abuse guards (the MCP layer enforces these; server-side rate limiting is planned)
GJQ_MAX_SHOTS=100000
GJQ_MAX_SUBMISSIONS_PER_SESSION=20
